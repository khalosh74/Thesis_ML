{
  "protocol_schema_version": "thesis-protocol-v1",
  "framework_mode": "confirmatory",
  "protocol_id": "thesis-canonical-nested",
  "protocol_version": "1.0.0",
  "status": "locked",
  "description": "Canonical confirmatory protocol variant using grouped nested tuning under the same scientific contract.",
  "notes": "This protocol demonstrates the grouped_nested_tuning methodology policy in the confirmatory path.",
  "scientific_contract": {
    "sample_unit": "beta_event",
    "target": "coarse_affect",
    "label_policy": "coarse_affect is derived from emotion using the fixed mapping in Thesis_ML.data.affect_labels.",
    "primary_metric": "balanced_accuracy",
    "secondary_metrics": [
      "macro_f1",
      "accuracy"
    ],
    "seed_policy": {
      "global_seed": 42,
      "per_suite_overrides_allowed": false
    }
  },
  "split_policy": {
    "primary_mode": "within_subject_loso_session",
    "secondary_mode": "frozen_cross_person_transfer",
    "grouping_field": "session",
    "transfer_constraints": "Directional transfer pairs are evaluated separately and train_subject/test_subject must differ."
  },
  "model_policy": {
    "selection_strategy": "nested_tuned",
    "models": [
      "ridge",
      "logreg",
      "linearsvc"
    ],
    "tuning_enabled": true,
    "nested_grouped_cv": true,
    "class_weight_policy": "none"
  },
  "methodology_policy": {
    "policy_name": "grouped_nested_tuning",
    "class_weight_policy": "none",
    "tuning_enabled": true,
    "inner_cv_scheme": "grouped_leave_one_group_out",
    "inner_group_field": "session",
    "tuning_search_space_id": "linear-grouped-nested-v1",
    "tuning_search_space_version": "1.0.0"
  },
  "metric_policy": {
    "primary_metric": "balanced_accuracy",
    "secondary_metrics": [
      "macro_f1",
      "accuracy"
    ]
  },
  "subgroup_reporting_policy": {
    "enabled": true,
    "subgroup_dimensions": [
      "label",
      "task",
      "modality",
      "session",
      "subject"
    ],
    "min_samples_per_group": 1
  },
  "control_policy": {
    "dummy_baseline": {
      "enabled": true,
      "suites": [
        "primary_controls"
      ]
    },
    "permutation": {
      "enabled": true,
      "metric": "balanced_accuracy",
      "n_permutations": 100,
      "suites": [
        "primary_controls"
      ]
    }
  },
  "interpretability_policy": {
    "enabled": true,
    "suites": [
      "primary_within_subject"
    ],
    "modes": [
      "within_subject_loso_session"
    ],
    "models": [
      "ridge",
      "logreg",
      "linearsvc"
    ],
    "supporting_evidence_only": true
  },
  "sensitivity_policy": {
    "role": "exploratory_only",
    "suites": []
  },
  "artifact_contract": {
    "required_run_artifacts": [
      "config.json",
      "metrics.json",
      "fold_metrics.csv",
      "fold_splits.csv",
      "predictions.csv",
      "subgroup_metrics.json",
      "subgroup_metrics.csv",
      "tuning_summary.json",
      "best_params_per_fold.csv",
      "spatial_compatibility_report.json",
      "interpretability_summary.json"
    ],
    "required_protocol_artifacts": [
      "protocol.json",
      "compiled_protocol_manifest.json",
      "claim_to_run_map.json",
      "suite_summary.json",
      "execution_status.json",
      "report_index.csv"
    ],
    "required_run_metadata_fields": [
      "framework_mode",
      "canonical_run",
      "methodology_policy_name",
      "class_weight_policy",
      "tuning_enabled",
      "primary_metric_name",
      "protocol_id",
      "protocol_version",
      "protocol_schema_version",
      "suite_id",
      "claim_ids"
    ]
  },
  "official_run_suites": [
    {
      "suite_id": "primary_within_subject",
      "description": "Primary confirmatory suite: within-subject held-out-session decoding.",
      "enabled": true,
      "suite_type": "primary",
      "claim_ids": [
        "C01_primary_within_subject_generalization"
      ],
      "split_mode": "within_subject_loso_session",
      "subject_source": "all_from_index",
      "controls_required": false,
      "interpretability_requested": true
    },
    {
      "suite_id": "secondary_cross_person_transfer",
      "description": "Secondary suite: frozen cross-person transfer in both directions for each subject pair.",
      "enabled": true,
      "suite_type": "secondary",
      "claim_ids": [
        "C02_cross_person_transfer_directional"
      ],
      "split_mode": "frozen_cross_person_transfer",
      "transfer_pair_source": "all_ordered_pairs_from_index",
      "controls_required": false,
      "interpretability_requested": false
    },
    {
      "suite_id": "primary_controls",
      "description": "Control suite for primary claim with dummy baseline and permutation testing.",
      "enabled": true,
      "suite_type": "control",
      "claim_ids": [
        "C03_primary_controls_dummy_and_permutation"
      ],
      "split_mode": "within_subject_loso_session",
      "subject_source": "all_from_index",
      "controls_required": true,
      "interpretability_requested": false
    }
  ]
}
