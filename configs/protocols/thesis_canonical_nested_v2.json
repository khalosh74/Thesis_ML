{
  "protocol_schema_version": "thesis-protocol-v1",
  "framework_mode": "confirmatory",
  "protocol_id": "thesis-canonical-nested",
  "protocol_version": "2.0.0",
  "status": "locked",
  "description": "Canonical confirmatory protocol variant using grouped nested tuning under the same scientific contract.",
  "notes": "This protocol demonstrates the grouped_nested_tuning methodology policy in the confirmatory path.",
  "scientific_contract": {
    "sample_unit": "beta_event",
    "target": "coarse_affect",
    "label_policy": "coarse_affect is derived from emotion using the fixed mapping in Thesis_ML.data.affect_labels.",
    "primary_metric": "balanced_accuracy",
    "secondary_metrics": [
      "macro_f1",
      "accuracy"
    ],
    "seed_policy": {
      "global_seed": 42,
      "per_suite_overrides_allowed": false
    }
  },
  "split_policy": {
    "primary_mode": "within_subject_loso_session",
    "secondary_mode": "frozen_cross_person_transfer",
    "grouping_field": "session",
    "transfer_constraints": "Directional transfer pairs are evaluated separately and train_subject/test_subject must differ."
  },
  "model_policy": {
    "selection_strategy": "nested_tuned",
    "models": [
      "ridge",
      "linearsvc"
    ],
    "tuning_enabled": true,
    "nested_grouped_cv": true,
    "class_weight_policy": "none"
  },
  "model_cost_policy": {
    "allowed_tiers": [
      "official_fast",
      "official_allowed"
    ],
    "max_projected_runtime_seconds_per_run": 5400
  },
  "methodology_policy": {
    "policy_name": "grouped_nested_tuning",
    "class_weight_policy": "none",
    "tuning_enabled": true,
    "inner_cv_scheme": "grouped_leave_one_group_out",
    "inner_group_field": "session",
    "tuning_search_space_id": "official-linear-grouped-nested-v2",
    "tuning_search_space_version": "2.0.0"
  },
  "metric_policy": {
    "primary_metric": "balanced_accuracy",
    "secondary_metrics": [
      "macro_f1",
      "accuracy"
    ]
  },
  "subgroup_reporting_policy": {
    "enabled": true,
    "subgroup_dimensions": [
      "label",
      "task",
      "modality",
      "session",
      "subject"
    ],
    "min_samples_per_group": 1
  },
  "feature_engineering_policy": {
    "feature_recipe_id": "baseline_standard_scaler_v1",
    "emit_feature_qc_artifacts": true
  },
  "data_policy": {
    "class_balance": {
      "enabled": true,
      "axes": [
        "overall",
        "subject",
        "session",
        "task",
        "modality"
      ],
      "min_class_fraction_warning": 0.05,
      "min_class_fraction_blocking": null
    },
    "missingness": {
      "enabled": true,
      "max_missing_fraction_warning": 0.1,
      "max_missing_fraction_blocking": null
    },
    "leakage": {
      "enabled": true,
      "fail_on_duplicate_sample_id": true,
      "warn_on_duplicate_beta_path": true,
      "fail_on_duplicate_beta_path": false,
      "fail_on_subject_overlap_for_transfer": true,
      "fail_on_cv_group_overlap": true
    },
    "external_validation": {
      "enabled": false,
      "mode": "compatibility_only",
      "require_compatible": false,
      "require_for_official_runs": false,
      "datasets": []
    },
    "required_index_columns": [
      "sample_id",
      "subject",
      "session",
      "task",
      "modality",
      "beta_path",
      "mask_path",
      "regressor_label",
      "emotion",
      "coarse_affect"
    ],
    "intended_use": "Official confirmatory thesis runs with grouped nested tuning.",
    "not_intended_use": [
      "Exploratory hypothesis generation from confirmatory outputs.",
      "External generalization claims from internal-only data."
    ],
    "known_limitations": [
      "External validation is compatibility-only in this phase."
    ]
  },
  "evidence_policy": {
    "repeat_evaluation": {
      "repeat_count": 3,
      "seed_stride": 1000
    },
    "confidence_intervals": {
      "method": "grouped_bootstrap_percentile",
      "confidence_level": 0.95,
      "n_bootstrap": 1000,
      "seed": 2026
    },
    "paired_comparisons": {
      "method": "paired_sign_flip_permutation",
      "n_permutations": 5000,
      "alpha": 0.05,
      "require_significant_win": false
    },
    "permutation": {
      "alpha": 0.05,
      "minimum_permutations": 100,
      "require_pass_for_validity": false
    },
    "calibration": {
      "enabled": true,
      "n_bins": 10,
      "require_probabilities_for_validity": false
    },
    "required_package": {
      "require_dummy_baseline": true,
      "require_permutation_control": true,
      "require_untuned_baseline_if_tuning": true
    }
  },
  "control_policy": {
    "dummy_baseline": {
      "enabled": true,
      "suites": [
        "primary_controls"
      ]
    },
    "permutation": {
      "enabled": true,
      "metric": "balanced_accuracy",
      "n_permutations": 100,
      "suites": [
        "primary_controls"
      ]
    }
  },
  "interpretability_policy": {
    "enabled": true,
    "suites": [
      "primary_within_subject"
    ],
    "modes": [
      "within_subject_loso_session"
    ],
    "models": [
      "ridge",
      "linearsvc"
    ],
    "supporting_evidence_only": true
  },
  "sensitivity_policy": {
    "role": "exploratory_only",
    "suites": []
  },
  "artifact_contract": {
    "required_run_artifacts": [
      "config.json",
      "metrics.json",
      "dataset_card.json",
      "dataset_card.md",
      "dataset_summary.json",
      "dataset_summary.csv",
      "data_quality_report.json",
      "class_balance_report.csv",
      "missingness_report.csv",
      "leakage_audit.json",
      "external_dataset_card.json",
      "external_dataset_summary.json",
      "external_validation_compatibility.json",
      "fold_metrics.csv",
      "fold_splits.csv",
      "predictions.csv",
      "cv_split_manifest.json",
      "cv_split_manifest.csv",
      "subgroup_metrics.json",
      "subgroup_metrics.csv",
      "tuning_summary.json",
      "best_params_per_fold.csv",
      "spatial_compatibility_report.json",
      "feature_qc_summary.json",
      "feature_qc_selected_samples.csv",
      "interpretability_summary.json",
      "calibration_summary.json",
      "calibration_table.csv"
    ],
    "required_protocol_artifacts": [
      "protocol.json",
      "compiled_protocol_manifest.json",
      "claim_to_run_map.json",
      "suite_summary.json",
      "execution_status.json",
      "repeated_run_metrics.csv",
      "repeated_run_summary.json",
      "confidence_intervals.json",
      "metric_intervals.csv",
      "report_index.csv",
      "claim_outcomes.json"
    ],
    "required_run_metadata_fields": [
      "framework_mode",
      "canonical_run",
      "methodology_policy_name",
      "class_weight_policy",
      "tuning_enabled",
      "feature_recipe_id",
      "model_cost_tier",
      "projected_runtime_seconds",
      "evidence_run_role",
      "repeat_id",
      "repeat_count",
      "base_run_id",
      "primary_metric_name",
      "data_policy_effective",
      "protocol_id",
      "protocol_version",
      "protocol_schema_version",
      "suite_id",
      "claim_ids"
    ]
  },
  "claims": [
    {
      "claim_id": "C01_primary_within_subject_generalization",
      "title": "Primary within-subject generalization claim",
      "description": "Within-subject held-out-session decoding is the primary confirmatory claim.",
      "role": "primary",
      "category": "within_person_decoding",
      "estimand_scope": "within_subject_loso_session",
      "decision_metric": "balanced_accuracy",
      "decision_rule": "above_baseline_and_permutation",
      "suite_ids": [
        "primary_within_subject"
      ],
      "baseline_required": true,
      "permutation_required": true,
      "interpretation_limits": []
    },
    {
      "claim_id": "C02_cross_person_transfer_directional",
      "title": "Secondary cross-person transfer claim",
      "description": "Cross-person transfer is secondary evidence and must not be treated as primary confirmatory evidence.",
      "role": "secondary",
      "category": "cross_person_transfer",
      "estimand_scope": "frozen_cross_person_transfer",
      "decision_metric": "balanced_accuracy",
      "decision_rule": "descriptive_only",
      "suite_ids": [
        "secondary_cross_person_transfer"
      ],
      "baseline_required": false,
      "permutation_required": false,
      "interpretation_limits": [
        "Does not substitute for the primary claim",
        "Must not be interpreted as primary confirmatory evidence"
      ]
    },
    {
      "claim_id": "C03_primary_controls_dummy_and_permutation",
      "title": "Primary controls evidence claim",
      "description": "Dummy baseline and permutation testing support the validity of the primary confirmatory analysis.",
      "role": "supporting",
      "category": "control_evidence",
      "estimand_scope": "within_subject_loso_session",
      "decision_metric": "balanced_accuracy",
      "decision_rule": "supporting_evidence_only",
      "suite_ids": [
        "primary_controls"
      ],
      "baseline_required": false,
      "permutation_required": false,
      "interpretation_limits": [
        "Supports validity of the primary analysis",
        "Does not substitute for the primary claim"
      ]
    }
  ],
  "success_criteria": {
    "primary_claim_id": "C01_primary_within_subject_generalization",
    "require_dummy_baseline_outperformance": true,
    "require_permutation_pass": true,
    "permutation_alpha": 0.05,
    "require_complete_primary_suite_evidence": true,
    "secondary_cannot_substitute_for_primary": true,
    "supporting_cannot_substitute_for_primary": true,
    "transfer_is_secondary_only": true,
    "interpretability_is_supporting_only": true
  },
  "official_run_suites": [
    {
      "suite_id": "primary_within_subject",
      "description": "Primary confirmatory suite: within-subject held-out-session decoding.",
      "enabled": true,
      "suite_type": "primary",
      "claim_ids": [
        "C01_primary_within_subject_generalization"
      ],
      "split_mode": "within_subject_loso_session",
      "subject_source": "all_from_index",
      "controls_required": false,
      "interpretability_requested": true
    },
    {
      "suite_id": "secondary_cross_person_transfer",
      "description": "Secondary suite: frozen cross-person transfer in both directions for each subject pair.",
      "enabled": true,
      "suite_type": "secondary",
      "claim_ids": [
        "C02_cross_person_transfer_directional"
      ],
      "split_mode": "frozen_cross_person_transfer",
      "transfer_pair_source": "all_ordered_pairs_from_index",
      "controls_required": false,
      "interpretability_requested": false
    },
    {
      "suite_id": "primary_controls",
      "description": "Control suite for primary claim with dummy baseline and permutation testing.",
      "enabled": true,
      "suite_type": "control",
      "claim_ids": [
        "C03_primary_controls_dummy_and_permutation"
      ],
      "split_mode": "within_subject_loso_session",
      "subject_source": "all_from_index",
      "controls_required": true,
      "interpretability_requested": false
    }
  ]
}

