{
  "schema_version": "release-evidence-v1",
  "required_run_artifacts": [
    "metrics.json",
    "fold_metrics.csv",
    "fold_splits.csv",
    "predictions.csv",
    "subgroup_report.csv",
    "spatial_report.json",
    "run_status.json"
  ],
  "required_release_artifacts": [
    "release_manifest.json",
    "release_summary.json",
    "evidence_verification.json",
    "dataset_snapshot.json",
    "warnings.json",
    "deviations.json",
    "artifacts/scope/selected_samples.csv",
    "artifacts/scope/scope_manifest.json",
    "verification/scope_alignment_verification.json"
  ],
  "required_control_artifacts": [
    "suite_summary.json",
    "deviation_log.json",
