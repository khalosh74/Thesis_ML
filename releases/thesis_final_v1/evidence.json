    "run_class",
    "release_id",
    "release_version",
    "release_hash",
    "science_hash",
    "execution_hash",
    "environment_hash",
    "evidence_hash",
    "claims_hash",
    "dataset_manifest_path",
    "dataset_fingerprint",
    "git_commit",
    "git_dirty",
    "python_version",
    "platform",
    "timestamp_utc",
    "parent_run_id",
    "status",
    "promotable",
    "official",
    "cache_policy",
    "command_line",
    "compiled_scope_manifest_path",
    "selected_samples_path",
    "selected_sample_ids_sha256",
    "scope_alignment_passed"
  ],
  "verify_dataset_fingerprint": true,
  "verify_science_hash": true,
  "verify_execution_hash": true,
  "verify_environment_hash": true,
  "verify_claims_hash": true
}
