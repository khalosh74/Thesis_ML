{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Release Environment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "official_python",
    "requires_uv_lock",
    "cpu_only_official",
    "supported_os",
    "required_project_scripts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "release-environment-v1"
    },
    "official_python": {
      "type": "string",
      "minLength": 1
    },
    "requires_uv_lock": {
      "type": "boolean"
    },
    "cpu_only_official": {
      "type": "boolean"
    },
    "supported_os": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "windows",
          "linux"
        ]
      },
      "uniqueItems": true
    },
    "required_project_scripts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

